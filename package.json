{
  "name": "brex",
  "version": "2.0.0",
  "description": "Unofficial TypeScript SDK for the Brex API, generated deterministically from Brex's OpenAPI specs. Tree-shakeable, ESM-only, zero dependencies.",
  "keywords": [
    "brex",
    "api",
    "sdk",
    "typescript",
    "openapi",
    "expenses",
    "payments",
    "fintech"
  ],
  "license": "MIT",
  "author": "Sanil Chawla",
  "repository": "github:slingshot/brex",
  "homepage": "https://slingshot.github.io/brex",
  "bugs": "https://github.com/slingshot/brex/issues",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "bun@1.3.14",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./accounting": {
      "types": "./dist/accounting.d.ts",
      "default": "./dist/accounting.js"
    },
    "./budgets": {
      "types": "./dist/budgets.d.ts",
      "default": "./dist/budgets.js"
    },
    "./expenses": {
      "types": "./dist/expenses.d.ts",
      "default": "./dist/expenses.js"
    },
    "./fields": {
      "types": "./dist/fields.d.ts",
      "default": "./dist/fields.js"
    },
    "./onboarding": {
      "types": "./dist/onboarding.d.ts",
      "default": "./dist/onboarding.js"
    },
    "./payments": {
      "types": "./dist/payments.d.ts",
      "default": "./dist/payments.js"
    },
    "./team": {
      "types": "./dist/team.d.ts",
      "default": "./dist/team.js"
    },
    "./transactions": {
      "types": "./dist/transactions.d.ts",
      "default": "./dist/transactions.js"
    },
    "./travel": {
      "types": "./dist/travel.d.ts",
      "default": "./dist/travel.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "default": "./dist/webhooks.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "lefthook install",
    "sync-specs": "bun scripts/sync-specs.ts",
    "generate": "bun scripts/generate.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.lib.json",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "test": "bun test",
    "check:package": "publint && attw --pack . --profile esm-only",
    "release": "bun run generate && bun run build && changeset publish"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.5",
    "@biomejs/biome": "2.5.5",
    "@changesets/cli": "2.31.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@types/bun": "1.3.14",
    "lefthook": "2.1.10",
    "openapi-typescript": "7.13.0",
    "publint": "0.3.21",
    "tsdown": "0.22.12",
    "typescript": "5.9.3",
    "yaml": "2.9.0"
  }
}
